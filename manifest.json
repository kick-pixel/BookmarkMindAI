{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.0.0",
  "minimum_chrome_version": "114",
  "default_locale": "zh_CN",
  "description": "__MSG_extDescription__",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "__MSG_extName__"
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "permissions": [
    "bookmarks",
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "permissions",
    "sidePanel",
    "contextMenus",
    "notifications",
    "alarms"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+B"
      },
      "description": "__MSG_openBookmarkMindAI__"
    },
    "save-current-page": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "__MSG_saveCurrentPageCommand__"
    },
    "open-side-panel": {
      "suggested_key": {
        "default": "Alt+Shift+M"
      },
      "description": "__MSG_openSidePanelCommand__"
    }
  }
}
